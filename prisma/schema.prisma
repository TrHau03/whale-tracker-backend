// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id          String   @id @default(uuid())
  txHash      String   @unique
  fromAddress String
  toAddress   String
  asset       String
  value       Float
  blockNum    String
  timestamp   DateTime
  isAnomaly   Boolean  @default(false)
  riskScore   Float?
  insertedAt  DateTime @default(now())
}

model WebhookEvent {
  id             String            @id @default(cuid())
  eventId        String            @unique
  webhookId      String
  eventType      String
  network        String?
  sequenceNumber String?
  createdAt      DateTime
  receivedAt     DateTime          @default(now())
  signature      String?
  rawBody        String
  payload        Json
  activities     WebhookActivity[]

  @@index([webhookId, createdAt])
  @@index([eventType, createdAt])
}

model WebhookActivity {
  id                   String       @id @default(cuid())
  webhookEventId       String
  sourceKind           String
  activityIndex        Int
  txHash               String?
  blockNum             String?
  category             String?
  fromAddress          String?
  toAddress            String?
  assetSymbol          String?
  assetAddress         String?
  rawValue             String?
  value                Decimal?     @db.Decimal(78, 18)
  accountAddress       String?
  txIndex              Int?
  gasPrice             String?
  maxFeePerGas         String?
  maxPriorityFeePerGas String?
  gas                  Int?
  txStatus             Int?
  gasUsed              Int?
  cumulativeGasUsed    Int?
  effectiveGasPrice    String?
  createdContract      String?
  tokenId              String?
  logIndex             String?
  removed              Boolean?
  payload              Json
  createdAt            DateTime     @default(now())
  webhookEvent         WebhookEvent @relation(fields: [webhookEventId], references: [id], onDelete: Cascade)

  @@unique([webhookEventId, activityIndex])
  @@index([txHash])
  @@index([blockNum])
  @@index([assetAddress])
  @@index([accountAddress])
}
